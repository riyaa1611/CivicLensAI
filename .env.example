# CivicLens Environment Variables Example
# Copy this to your deployment platform (Render/Vercel)

# --- Backend (Render) ---
# Your Neon.tech or other PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenRouter API Key for LLM access
OPENROUTER_API_KEY=your_openrouter_key_here

# Pinecone configuration (Free tier recommended)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_HOST=your_pinecone_index_host_here
PINECONE_INDEX_NAME=civiclens-policies

# Optional ScaleDown API Key
# SCALEDOWN_API_KEY=your_scaledown_key_here

# Ingestion interval (default 6 hours)
INGESTION_INTERVAL_HOURS=6

# --- Frontend (Vercel) ---
# The URL of your Render backend API
VITE_API_BASE_URL=https://your-backend-url.onrender.com/api/v1
